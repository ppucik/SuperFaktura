{
  "name": "superfaktura/ares-client",
  "description": "PHP library for fetching company data from Czech ARES register",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "psr/log": "^3.0",
    "symfony/http-client": "^8.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "SuperFaktura\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SuperFaktura\\Tests\\": "tests/"
    }
  }
}
